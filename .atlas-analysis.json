{
  "projectType": "cli-tool",
  "projectName": "stdai",
  "projectDescription": "A CLI primitive that captures agent work as cryptographically signed, durable artifacts with full-text search and provenance lineage.",
  "theme": "luma",
  "primaryColor": "#242b2c",
  "lightColor": "#6a6a6d",
  "darkColor": "#ebeaea",
