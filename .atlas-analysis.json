  "keyFeatures": [
    "Cryptographically signed artifacts using Ed25519 key pairs",
    "Pipe-transparent: stdin forwarded to stdout while capturing work",
    "Full-text search across artifacts with project scoping",
    "Provenance DAG via --based-on lineage links",
    "Automatic metadata capture (git repo, branch, commit, cwd, hostname)",
    "Content-addressed blob store with SHA-256 deduplication",
    "SQLite FTS5 full-text search index",
    "Global store with cross-project lineage traversal",
    "ULID-based sortable artifact IDs",
    "JSON output for machine-readable agent integration"
  ],
  "publicApiSurface": [
    "stdai write --kind <kind> --content <text> [--based-on <id>] [--tag <tag>] [--identity <addr>]",
    "stdai find <query> [--kind <kind>] [--tag <tag>] [--all] [--project <name>]",
    "stdai show <id> [--json] [--content-only]",
    "stdai list [--kind <kind>] [--tag <tag>] [--all] [--limit <n>]",
    "stdai upstream <id> [--recursive] [--json]",
    "stdai downstream <id> [--recursive] [--json]",
    "stdai identity new --label <label>",
    "stdai identity list [--json]",
    "stdai identity show <address>",
    "stdai identity export <address>",
    "stdai identity import --pubkey <hex> [--label <label>]",
    "stdai verify <id> [--json]",
    "stdai projects [--json]",
    "stdai context [--json]",
    "stdai doctor"
  ]
}
